{
  "name": "@sxzz/create",
  "type": "module",
  "version": "0.16.0",
  "packageManager": "pnpm@10.33.2",
  "description": "Command-line for creating projects from templates.",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/sxzz/create#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sxzz/create.git"
  },
  "bugs": {
    "url": "https://github.com/sxzz/create/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "create": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "node ./src/cli.ts",
    "typecheck": "tsgo --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "ansis": "^4.2.0",
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "empathic": "^2.0.0",
    "giget": "^3.2.0",
    "tinyexec": "^1.1.1",
    "tinyglobby": "^0.2.16",
    "unconfig": "^7.5.0",
    "yaml": "^2.8.3"
  },
  "inlinedDependencies": {
    "@antfu/utils": "9.3.0",
    "replace-in-file": "8.4.0"
  },
  "devDependencies": {
    "@antfu/utils": "^9.3.0",
    "@sxzz/eslint-config": "^8.0.0",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260503.1",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "replace-in-file": "^8.4.0",
    "tsdown": "^0.21.7",
    "tsdown-preset-sxzz": "^0.5.0",
    "typescript": "^6.0.2",
    "unplugin-unused": "^0.5.7"
  },
  "prettier": "@sxzz/prettier-config"
}
